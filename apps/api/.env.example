# ===============================
# 数据库配置 (SQLite via LibSQL)
# ===============================
# 本地开发使用本地文件
DATABASE_URL=file:./sqlite.db
# 生产环境示例（挂载到 Docker Volume 时推荐使用绝对路径）
# DATABASE_URL=file:/app/data/pms.db

# ===============================
# Better Auth 配置
# ===============================
# 使用以下命令生成随机密钥: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here
# 后端 API 的完整基础 URL（生产环境改为你的域名）
BETTER_AUTH_URL=http://localhost:3100

# ===============================
# CORS / 前端地址配置
# ===============================
# 允许跨域的前端地址，多个地址用英文逗号分隔
# 生产环境示例: CLIENT_ORIGIN=https://pms.jimmylee.top
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ===============================
# 邮件服务配置 (SMTP)
# ===============================
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
# 你的 QQ 邮箱地址
SMTP_USER=your-qq@qq.com
# QQ 邮箱授权码（非登录密码，在 QQ 邮箱设置 -> 账户 中获取）
SMTP_PASS=your-qq-email-authorization-code
# 发件人显示名称和地址
SMTP_FROM="PMS 项目管理 <your-qq@qq.com>"
